# MongoDB
MONGODB_URI=mongodb://weemeal:weemeal_dev@localhost:27017/weemeal?authSource=admin

# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0-dev

# Image Storage (File System)
# Directory for storing recipe images (mounted as Docker volume in production)
# In Docker: /data/images (mount to host path like /mnt/user/appdata/weemeal/images)
# Local dev: ./data/images
IMAGES_DIR=./data/images

# Optional: Anthropic for AI tag generation
ANTHROPIC_API_KEY=

# Admin secret for protected endpoints (e.g., /api/admin/migrate-images)
ADMIN_SECRET=
